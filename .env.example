# ── Repo-level environment variables ─────────────────────────────────
# This file is the template. The real .env is generated by init-nas.sh.
# Do not edit .env directly - re-run init-nas.sh to regenerate it.

# Root directory where all Dockge stack data volumes are stored.
# init-nas.sh auto-detects and overwrites this value after git clone.
# Override before running init-nas.sh if your Dockge layout differs:
#   STACK_ROOT_OVERRIDE=/volume1/docker/dockge/stacks sudo bash scripts/init-nas.sh
# Local Mac: point at your git clone, e.g. /Users/you/dev/dockge/stacks
STACK_ROOT=/volume1/docker/dockge/stacks

# Default UID/GID - root for Synology, override for local dev.
PUID=0
PGID=0

# Timezone - used by all stacks via ${TZ:-America/New_York}
# Change if your NAS is in a different region.
TZ=America/New_York
