# Dummy values for `docker compose config` CI only — never use in production.
APP_SECRET=ci_dummy_app_secret_at_least_thirty_two_chars_long
SYNO_UID=1000
SYNO_GID=1000
CODE_SERVER_HASHED_PASSWORD=ci_placeholder
MYSQL_ROOT_PASSWORD=ci_root_pw
PMA_CONTROLPASS=ci_pma_control
PMA_BLOWFISH_SECRET=12345678901234567890123456789012
CF_Token=
DISCORD_WEBHOOK_URL=
WARP_API_KEY=ci_dummy_warp_api_key_not_real
TZ=America/New_York
WORKSPACE_PATH=/tmp/workspace
PUID=0
PGID=0
NOTIFY_DISCORD=false
TIMEZONE=America/New_York
NAS_IP=127.0.0.1
# linuxserver/github-desktop (compose interpolation; not real credentials)
GITHUB_DESKTOP_USER=ci_user
GITHUB_DESKTOP_PASSWORD=ci_dummy_github_desktop_password
GITHUB_DESKTOP_PORT=3405
# stacks/code-server — EXEMPT wide host binds (NAS layout; compose config -q only)
CODE_SERVER_HOST_DOCKER_BIND=/volume1/docker/dockge/stacks/code-server/host-docker-bind
CODE_SERVER_HOST_HOME_BIND=/volume1/docker/dockge/stacks/code-server/host-home-bind
# stacks/portainer — NAS paths for compose interpolation (CI: config -q only; dirs need not exist on runner)
PORTAINER_DATA_ROOT=/volume1/docker/portainer
PORTAINER_CERT_ROOT=/volume1/docker/portainer/certs
# stacks/zabbix (postgres + Zabbix services)
POSTGRES_DB=zabbix
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=ci_zabbix_postgres_password_dummy
# stacks/rag-stack — compose config -q only (not production secrets)
ANYTHINGLLM_JWT_SECRET=ci_anythingllm_jwt_secret_hex_like_openssl_rand_hex32_placeholder
PIPELINES_API_KEY=ci_pipelines_api_key_placeholder_only
