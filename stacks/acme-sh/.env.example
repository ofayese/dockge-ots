# Stack: acme-sh
# Required (secrets):
CF_Token=                              # Cloudflare API token with Zone.DNS:Edit on relevant zones
DISCORD_WEBHOOK_URL=                   # Optional — Discord webhook for issue/renew notifications

# Optional (tunables — usually not changed):
TZ=America/New_York
PUID=0
PGID=0

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/volume1/docker/dockge/stacks
# Host path for ACME cert output (default Synology layout).
ACME_CERT_ROOT=/volume1/certs/acme
