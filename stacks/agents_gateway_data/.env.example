# Optional tunables (copy to .env - never commit .env)
# Synology NAS default: root in-container for bind mounts (override on Linux dev only).
PUID=0
PGID=0
TZ=America/New_York

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/volume1/docker/dockge/stacks
