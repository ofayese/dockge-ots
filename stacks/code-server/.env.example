# Identity/timezone
PUID=0
PGID=0
TZ=America/New_York
DOCKER_USER=ofayese
PROXY_DOMAIN=*.olutechsys.com

# code-server login hash (argon2id), single-quoted
CODE_SERVER_HASHED_PASSWORD='$argon2id$v=19$m=65536,t=3,p=4$REPLACE_ME_SALT$REPLACE_ME_HASH'

# MySQL
MYSQL_ROOT_PASSWORD=REPLACE_ME_ROOT_PASSWORD
MYSQL_DATABASE=development
MYSQL_USER=developer

# phpMyAdmin control account (used by PMA and pma init script)
PMA_CONTROLUSER=pma
PMA_CONTROLPASS=REPLACE_ME_PMA_CONTROL_PASSWORD

# Must be exactly 32 chars
PMA_BLOWFISH_SECRET=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Leave empty unless reverse proxy requires explicit absolute URI
PMA_ABSOLUTE_URI=

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/dockge/stacks

# EXEMPT wide host binds (set to your NAS paths — see stack README; CI uses /tmp placeholders).
CODE_SERVER_HOST_DOCKER_BIND=/tmp/code-server-host-docker-bind
CODE_SERVER_HOST_HOME_BIND=/tmp/code-server-host-home-bind
