# Identity/timezone
PUID=0
PGID=0
TZ=America/New_York
DOCKER_USER=laolufayese
PROXY_DOMAIN=*.olutechsys.com

# code-server login password (plain text in local .env only; file is gitignored)
CODE_SERVER_PASSWORD=REPLACE_ME_CODE_SERVER_PASSWORD

# MySQL
MYSQL_ROOT_PASSWORD=REPLACE_ME_ROOT_PASSWORD
MYSQL_DATABASE=development
MYSQL_USER=developer

# phpMyAdmin control account (used by PMA and pma init script)
PMA_CONTROLUSER=pma
PMA_CONTROLPASS=REPLACE_ME_PMA_CONTROL_PASSWORD

# Must be exactly 32 chars
PMA_BLOWFISH_SECRET=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Leave empty unless reverse proxy requires explicit absolute URI
PMA_ABSOLUTE_URI=

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/volume1/docker/dockge/stacks

# EXEMPT wide host binds - under this stack dir (create with init-nas.sh or mkdir -p).
# Defaults match ${STACK_ROOT}/code-server/… on the NAS.
CODE_SERVER_HOST_DOCKER_BIND=/volume1/@docker
CODE_SERVER_HOST_HOME_BIND=/volume1/homes/laolufayese
