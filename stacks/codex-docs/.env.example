# Stack: codex-docs
# Copy to .env in this directory before `docker compose up`.

# Required — session/crypto secret for Codex.Docs (generate a long random string)
APP_SECRET=

# Optional
TZ=America/New_York

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
