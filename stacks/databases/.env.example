# Stack: databases
# Secrets are file-based (not env). See databases/secrets/*.txt and the
# `secrets:` block in compose.yaml. Files must be mode 0600 and gitignored.

# Optional (tunables):
TZ=America/New_York

# (DB names / users are intentionally inline in compose.yaml — non-secret defaults.)

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/dockge/stacks
PUID=0
PGID=0
