# Stack: dozzle
# Auth users live in users.yml (mounted into /data/users.yml inside the container).
# Generate users with:
#   docker run --rm amir20/dozzle:latest generate <username> --password <pass>
# and append output to dozzle/users.yml.

# Optional (tunables):
TZ=America/New_York
DOZZLE_AUTH_PROVIDER=simple
