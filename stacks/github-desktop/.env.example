# ── github-desktop ────────────────────────────────────────────────
# Port the web UI is accessible on
GITHUB_DESKTOP_PORT=3405

# KasmVNC web interface credentials — change before deploying
GITHUB_DESKTOP_USER=yourname
GITHUB_DESKTOP_PASSWORD=changeme

# Timezone — select from https://timezone.mariushosting.com/
# Default matches NAS location (Eastern Time)
TZ=America/New_York

# ── Standard repo vars ────────────────────────────────────────────
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
