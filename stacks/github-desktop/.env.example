# Stack: github-desktop
# Image: ghcr.io/linuxserver/github-desktop (LinuxServer.io KasmVNC)

# --- Identity & timezone ---
PUID=1026
PGID=100
TZ=America/New_York

# --- Web UI credentials ---
# Username shown on the KasmVNC login page
CUSTOM_USER=admin
# Plain-text password — avoid special characters (! @ # $ etc.) per linuxserver docs
PASSWORD=REPLACE_ME_STRONG_PASSWORD

# --- UI title (browser tab / window bar) ---
TITLE=Github-Desktop

# --- Port (host-side, maps to container:3001 HTTPS) ---
# Synology Reverse Proxy destination should point at this port on localhost
HOST_PORT=3405
