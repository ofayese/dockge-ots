# Stack: grafana-prom
# Copy to .env (never commit .env).
# SYNO_* avoids bash reserved UID/GID in tooling that sources env files.

SYNO_UID=0
SYNO_GID=0
TIMEZONE=America/New_York

# Used in prom.yml for SNMP targets — align with your NAS management IP.
NAS_IP=192.168.1.18

GRAFANA_PORT=3340
PROMETHEUS_PORT=9090

# Watchtower Prometheus scrape uses bearer_token_file (not this .env):
# create secrets/watchtower_bearer_token.txt — see secrets/README.md and watchtower/compose.yaml.

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
