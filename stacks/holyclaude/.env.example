# Stack: holyclaude
# Required:
PUID=0
PGID=0
TZ=America/New_York
# Workspace is mounted from ${STACK_ROOT} in compose (same as the Dockge stacks root).

# Notifications (Discord first; keep local-only in .env):
DISCORD_WEBHOOK_URL=
NOTIFY_DISCORD=true

# Optional provider/auth variables:
ANTHROPIC_API_KEY=

CURSOR_API_KEY=
OLLAMA_HOST= # use ${STACK_ROOT}/ollama/compose.yaml stack URL (e.g. http://10.0.1.15:11434)

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/dockge/stacks
