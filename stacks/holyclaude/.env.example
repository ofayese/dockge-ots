# Stack: holyclaude
# CloudCLI web IDE + offline AI integration for NAS and remote machines.
# See docs/tasks/OLLAMA_MODEL_SELECTION_DS723.md for model guide.

# ── Identity ──────────────────────────────────────────────────────────────────
PUID=0
PGID=0
TZ=America/New_York

# ── Workspace (OPERATOR EXCEPTION - not under STACK_ROOT) ─────────────────────
# NAS default: DSM user home. Change per machine:
#   NAS (Container Manager): /volume1/homes/laolufayese
#   hpdevcore (Windows WSL2): /home/laolufayese
#   otsmbpro16 (Mac):         /Users/laolufayese
HOLYCLAUDE_WORKSPACE=/volume1/homes/laolufayese

# ── Offline / local AI stack ──────────────────────────────────────────────────
# Ollama LLM inference (otsai-server on NAS, or localhost if running locally)
OLLAMA_HOST=http://10.0.1.15:11434

# AnythingLLM RAG API (rag-stack on NAS)
ANYTHINGLLM_API_URL=http://10.0.1.15:3002
# Get token from: AnythingLLM UI → Settings → API Keys → Generate
ANYTHINGLLM_API_TOKEN=

# Qdrant vector DB (rag-stack on NAS)
QDRANT_URL=http://10.0.1.15:6333
QDRANT_API_KEY=

# ── Cloud provider keys (optional - leave blank for fully offline use) ─────────
ANTHROPIC_API_KEY=
CURSOR_API_KEY=

# ── Notifications ─────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
NOTIFY_DISCORD=false

# ── Host bind-mount root ───────────────────────────────────────────────────────
STACK_ROOT=/volume1/docker/dockge/stacks
