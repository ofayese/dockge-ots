# Stack: homepage
# All keys are tunables, not secrets.
TZ=America/New_York

# Comma-separated list of host:port allowed for direct access.
# Update when HAProxy frontend hostnames change (see _haproxy/PROPOSAL.md).
HOMEPAGE_ALLOWED_HOSTS=10.0.1.15:7575,otsorundscore.olutechsys.com:7575,otsorundscore.olutech.systems:7575,localhost:7575

# Dockge widget credentials (used by services.yaml widget block).
# These are secrets — keep in .env (gitignored), never commit real values.
DOCKGE_USERNAME=
DOCKGE_PASSWORD=

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
