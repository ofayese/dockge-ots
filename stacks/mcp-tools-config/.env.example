# mcp-tools-config is catalog/config YAML - no Compose env interpolation by default.
# Add keys here only if you introduce a wrapper compose stack; never commit secrets.

# Repo NAS policy (HIVE_OBJECTIVE.md) - not read by the Busybox placeholder; reserved for consistency.
PUID=0
PGID=0

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/volume1/docker/dockge/stacks
