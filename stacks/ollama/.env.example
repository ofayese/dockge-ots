# Stack: ollama (otsai-server + otsai-webui)
# No env-borne secrets — open-webui auth state lives in the mounted volume.

# Optional (tunables):
TZ=America/New_York
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
DEFAULT_MODELS=phi4:mini

# Override if HAProxy frontend hostname changes:
WEBUI_URL=https://ai.otsorundscore.olutechsys.com

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
