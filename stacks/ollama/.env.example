# Stack: ollama (otsai-server + ollama-model-init + otsai-webui)
# Hardware: DS723+, AMD Ryzen R1600 (2 cores), 32 GB RAM, CPU-only, no GPU.
# See docs/tasks/OLLAMA_MODEL_SELECTION_DS723.md for full model guide.

# ── Timezone ───────────────────────────────────────────────────────────────────
TZ=America/New_York

# ── CPU tuning - keep parallel=1 for single-core inference ────────────────────
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1

# Model idle timeout before unloading from RAM.
# 30m: good balance for interactive sessions (CPU reload takes 15-60s).
# -1:  keep loaded indefinitely. 5m: conserve RAM between infrequent sessions.
OLLAMA_KEEP_ALIVE=30m

# ── Automated model pull (ollama-model-init service) ──────────────────────────
# Each tier is a space-separated list of model tags.
# Set any tier to "" to skip it entirely.
# Models already on disk are SKIPPED - the service is idempotent.

# Tier 1 - always pull (small, fast, required)
# nomic-embed-text: REQUIRED for AnythingLLM embeddings - always in Tier 1
OLLAMA_TIER1_MODELS=phi4:mini nomic-embed-text llama3.2:3b

# Tier 2 - primary working models (~15-25 min combined on first pull)
OLLAMA_TIER2_MODELS=qwen2.5-coder:7b llama3.1:8b

# Tier 3 - secondary models (set to "" to skip on constrained networks)
OLLAMA_TIER3_MODELS=deepseek-r1:7b mistral:7b qwen2.5:7b

# ── Open-WebUI default model dropdown ──────────────────────────────────────────
# Comma-separated. Does NOT auto-pull - ollama-model-init handles that.
DEFAULT_MODELS=phi4:mini,qwen2.5-coder:7b,nomic-embed-text

# ── Open-WebUI URL (for HAProxy/Traefik routing) ──────────────────────────────
WEBUI_URL=https://oai.otsorundscore.olutechsys.com

# ── Host bind-mount root (init-nas.sh sets this on the NAS) ───────────────────
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
