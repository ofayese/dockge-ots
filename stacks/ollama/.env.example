# Stack: ollama (otsai-server + otsai-webui)
# Hardware: DS723+, AMD Ryzen R1600 (2 cores), 32 GB RAM, CPU-only, no GPU.
# See docs/tasks/OLLAMA_MODEL_SELECTION_DS723.md for full model guide.

# Timezone
TZ=America/New_York

# CPU tuning - keep parallel=1 and max_loaded=1 for single-core inference
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1

# Model idle timeout before unloading from RAM.
# 30m: good balance for interactive sessions (CPU reload takes 15-60s).
# -1:  keep loaded indefinitely (if only one model used).
# 5m:  conserve RAM between infrequent sessions.
OLLAMA_KEEP_ALIVE=30m

# Open-WebUI default model dropdown (does NOT auto-pull - pull manually).
# Pull command: sudo docker exec otsai-server ollama pull <model>
DEFAULT_MODELS=phi4:mini,qwen2.5-coder:7b,nomic-embed-text

# Override if reverse proxy hostname changes
WEBUI_URL=https://ai.otsorundscore.olutechsys.com

# Host bind-mount root (init-nas.sh sets this on the NAS)
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
