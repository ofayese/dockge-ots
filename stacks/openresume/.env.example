# Stack: openresume
# All keys are tunables, no secrets (resume data is client-side localStorage).
TZ=America/New_York

# Override if HAProxy frontend hostname changes:
NEXT_PUBLIC_BASE_URL=https://resume.otsorundscore.olutechsys.com

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
