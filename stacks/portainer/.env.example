# Copy to .env or set in Dockge. Values from Portainer: Environments > Add environment > Edge agent.

EDGE_ID=
EDGE_KEY=

# Optional. Defaults to tasks.portainer_edge_agent (matches docker service create --name).
# With docker stack deploy -c compose.yaml mystack, set:
#   AGENT_CLUSTER_ADDR=tasks.mystack_portainer_edge_agent
# AGENT_CLUSTER_ADDR=

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0

# Portainer operator paths (outside STACK_ROOT — see README.md). Paths must exist before compose up.
# Example (Synology): agent expects cert.pem + key.pem under CERT_ROOT (see compose.yaml).
#   sudo mkdir -p /volume1/docker/portainer/certs
#   sudo install -m 640 cert.pem key.pem /volume1/docker/portainer/certs/
#   sudo mkdir -p /volume1/docker/portainer
PORTAINER_DATA_ROOT=/volume1/docker/portainer
PORTAINER_CERT_ROOT=/volume1/docker/portainer/certs
