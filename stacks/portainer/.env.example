# Copy to .env or set in Dockge. Values from Portainer: Environments > Add environment > Edge agent.

EDGE_ID=
EDGE_KEY=

# Optional. Defaults to tasks.portainer_edge_agent (matches docker service create --name).
# With docker stack deploy -c compose.yaml mystack, set:
#   AGENT_CLUSTER_ADDR=tasks.mystack_portainer_edge_agent
# AGENT_CLUSTER_ADDR=

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/dockge/stacks
PUID=0
PGID=0

# Portainer operator paths (legacy — outside STACK_ROOT; set to your NAS paths).
PORTAINER_DATA_ROOT=/tmp/portainer-data
PORTAINER_CERT_ROOT=/tmp/portainer-certs
