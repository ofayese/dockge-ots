# Copy to .env (gitignored) on the NAS. STACK_ROOT is normally set at repo root.
# STACK_ROOT=/volume1/docker/dockge/stacks

TZ=America/New_York
PUID=0
PGID=0

# Monorepo root (parent of stacks/) — mounted read-only at /nas-repo unless you change compose to :rw for webhook pulls
DOCKGE_REPO_ROOT=/volume1/docker/dockge

# Passed into container as STACK_ROOT for fix-permissions.sh (same as host STACK_ROOT)
PSU_STACK_ROOT=/volume1/docker/dockge/stacks

ACME_CERT_ROOT=/volume1/certs/acme

# Dockge HTTP API (preferred over docker.sock for Monitor-DockgeStack.ps1)
DOCKGE_BASE_URL=http://10.0.1.15:5571
DOCKGE_USERNAME=
DOCKGE_PASSWORD=

# Webhook POST /api/v1/nas/pull — set in PSU Admin → Security → App Tokens; placeholder for documentation only
NAS_PULL_APP_TOKEN=

# Phase 2 — PSU REST (/api/v1/*) requires Bearer token matching this value (set before enabling endpoints)
PSU_AUTH_TOKEN=

# Dangerous operations (default off)
PSU_ALLOW_STACK_RESTART=0
PSU_REMEDIATION_ENABLED=0
# Docker on NAS host via SSH (see NAS_HOST_SSH_SETUP.md). Set SSH_KEY_PATH inside container (e.g. /ssh-keys/psu_remediation_key).
NAS_HOST_IP=
NAS_SSH_USER=
SSH_KEY_PATH=/ssh-keys/psu_remediation_key
# Host absolute path to stacks/ for docker compose over SSH (required if PSU_STACK_ROOT in container is /nas-repo/stacks).
NAS_HOST_STACKS_ROOT=/volume1/docker/dockge/stacks
# Optional: writable known_hosts path (default: /data/reports/_psu_ssh_known_hosts inside container).
# NAS_SSH_KNOWN_HOSTS_FILE=/data/reports/_psu_ssh_known_hosts
PSU_REMEDIATION_DOCKER_PRUNE=0
PSU_REMEDIATION_DISK_THRESHOLD_PCT=90
# Load/memory triage (requires nas-health memorySummary + PSU_ALLOW_STACK_RESTART=1 + SSH)
PSU_REMEDIATION_LOADAVG1_CRITICAL=8
PSU_REMEDIATION_MEM_AVAILABLE_RATIO_MIN=0.08
PSU_REMEDIATION_DOCKER_CPU_PCT=90
PSU_REMEDIATION_CPU_TRIAGE=0
# Safe Mode: degraded mdstat / btrfs uncorrectable (see dockge-jobs Invoke-PSUJob_AutoRemediation)
PSU_SAFE_MODE_ENABLED=0
# Comma-separated stack folder names under NAS_HOST_STACKS_ROOT (e.g. databases,ollama)
PSU_SAFE_MODE_STOP_STACKS=
# After Safe Mode, queue backup-snapshot job (1 default). Set 0 to skip dot-source + queue inside remediation worker.
PSU_SAFE_MODE_QUEUE_BACKUP=1
PSU_SAFE_MODE_WEBHOOK_URL=
PSU_SAFE_MODE_DISCORD_WEBHOOK=
# POST /api/v1/webhooks/nas-alert — if set, Synology sends X-PSU-Nas-Alert-Token or Bearer with this value; else use PSU_AUTH_TOKEN only.
PSU_NAS_ALERT_WEBHOOK_TOKEN=
PSU_GITOPS_ENABLED=0
# GitOps job: mount /nas-repo :rw, set identity, configure credentials on NAS (never commit secrets).
PSU_GITOPS_AUTO_COMMIT=0
PSU_GITOPS_AUTO_PUSH=0
# PSU_GITOPS_COMMIT_MESSAGE=chore(gitops): auto-sync drift configurations
PSU_GIT_USER_NAME=
PSU_GIT_USER_EMAIL=

# JSON job output directory inside the container (binds under psu-ots/data/reports on host)
PSU_REPORTS_ROOT=/data/reports

# PSU Gallery — strict by default (Import-PSUGalleryModules throws if any module missing).
# PSU_GALLERY_OPTIONAL=1 — allow partial import (staging only).
# PSU_GALLERY_INSTALL=1 — on container start, download modules from PSGallery before Universal.Server (needs HTTPS).
# PSU_GALLERY_INSTALL_STRICT=0 — install script continues if some packages fail (then import may still throw).
# PSU_GALLERY_INCLUDE_WINDOWS=1 — include Windows-only gallery names in install/import lists (non-Linux hosts).
PSU_GALLERY_OPTIONAL=0
PSU_GALLERY_INSTALL=0
PSU_GALLERY_INSTALL_STRICT=1
PSU_GALLERY_INCLUDE_WINDOWS=0
