# Stack: rag-stack
# Copy to .env and fill in secrets before `docker compose up`.
# Never commit .env — it is gitignored.

# ── Required secrets ──────────────────────────────────────────────────────────

# AnythingLLM JWT signing secret — generate with: openssl rand -hex 32
ANYTHINGLLM_JWT_SECRET=

# Open WebUI Pipelines API key — paste this into:
#   Open WebUI > Settings > Connections > Pipelines > API Key
# Generate with: openssl rand -hex 24
PIPELINES_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Qdrant REST/gRPC API key — leave blank to disable auth (LAN-only is fine without it)
QDRANT_API_KEY=

# GitHub personal access token for the GitHub RAG pipeline in Open WebUI Pipelines.
# Scopes needed: repo (read), read:org (optional for org repos).
# Leave blank to skip GitHub connector.
GITHUB_TOKEN=

# Ollama model used for chat inference in AnythingLLM (must be pulled on otsai-server)
ANYTHINGLLM_LLM_MODEL=phi4:mini

# Ollama embedding model (must be pulled on otsai-server first):
#   docker exec otsai-server ollama pull nomic-embed-text
ANYTHINGLLM_EMBED_MODEL=nomic-embed-text:latest

# Context window length for the chosen LLM
ANYTHINGLLM_MODEL_CTX=4096

# Timezone
TZ=America/New_York

# Host bind-mount root (init-nas.sh sets this on the NAS)
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
