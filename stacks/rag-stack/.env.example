# Stack: rag-stack
# Offline RAG pipeline: Qdrant + AnythingLLM + Open WebUI Pipelines.
# All inference routes to Ollama on this NAS (otsai-server, port 11434).
# Copy to .env and fill secrets before `docker compose up`.
# Never commit .env — it is gitignored.

# ── Required secrets ──────────────────────────────────────────────────────────

# AnythingLLM JWT signing secret
# Generate: openssl rand -hex 32
ANYTHINGLLM_JWT_SECRET=

# Open WebUI Pipelines API key
# Paste this in: Open WebUI > Settings > Connections > Pipelines > API Key
# Generate: openssl rand -hex 24
PIPELINES_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Qdrant API key — leave blank for LAN-only (no auth needed on trusted network)
QDRANT_API_KEY=

# GitHub PAT for the GitHub RAG pipeline in Open WebUI Pipelines.
# Scopes: repo (read), read:org (optional for org repos)
GITHUB_TOKEN=

# ── Model configuration ───────────────────────────────────────────────────────
# Primary LLM for chat/RAG queries (must be pulled on otsai-server):
#   qwen2.5-coder:7b — best coding + research 7B model in 2026
#   llama3.1:8b      — best general-purpose 8B (research, devops, docs)
#   phi4:mini        — fastest (3-7B, good for quick queries)
ANYTHINGLLM_LLM_MODEL=qwen2.5-coder:7b

# Context window for the chosen model
ANYTHINGLLM_MODEL_CTX=8192

# Embedding model (REQUIRED — must be pulled first):
#   sudo docker exec otsai-server ollama pull nomic-embed-text
# ollama-model-init auto-pulls this when the ollama stack starts.
ANYTHINGLLM_EMBED_MODEL=nomic-embed-text:latest

# ── Timezone and host paths ───────────────────────────────────────────────────
TZ=America/New_York
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
