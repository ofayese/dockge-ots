# ── remotely .env ─────────────────────────────────────────────────────────────
# Copy to .env and fill values before deploying.
# This file is committed. The populated .env is gitignored.

# Host bind-mount root - init-nas.sh sets this automatically on the NAS.
STACK_ROOT=/volume1/docker/dockge/stacks

# Standard fleet vars
PUID=0
PGID=0
TZ=America/New_York

# LAN IP of the reverse proxy Remotely is behind (Traefik, DSM reverse proxy, etc.)
# Used to whitelist X-Forwarded-For headers. Set to 0.0.0.0/0 to trust any upstream.
REMOTELY_KNOWN_PROXY=10.0.1.15

# Public HTTPS URL used by Remotely to generate agent installer download links.
# Must match the hostname your reverse proxy serves Remotely on.
REMOTELY_SERVER_URL=https://remotely.otsorundscore.olutechsys.com
