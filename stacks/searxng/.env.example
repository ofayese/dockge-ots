# Stack: searxng
# Tunables. Application secret_key lives in config/settings.yml (gitignored — see README).
TZ=America/New_York
UWSGI_WORKERS=4
UWSGI_THREADS=4

# Override if HAProxy frontend hostname changes:
SEARXNG_BASE_URL=https://search.otsorundscore.olutechsys.com/

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/dockge/stacks
PUID=0
PGID=0
