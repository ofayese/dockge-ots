# Stack: synology-api-bridge — internal DSM HTTP shim (FastAPI)
# Copy to .env (gitignored). Never commit secrets.

# Required — callers must send header X-Bridge-Secret with this exact value
BRIDGE_SHARED_SECRET=

# Optional — DSM web origin (no trailing slash), e.g. https://10.0.1.15:5001
DSM_BASE_URL=

# Optional — outbound timeout for DSM HTTP calls (seconds)
DSM_HTTP_TIMEOUT_SECONDS=5
