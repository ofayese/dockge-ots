# ── traefik-ots ────────────────────────────────────────────────────
# Cloudflare API token - same token as acme-sh stack (Zone.DNS:Edit)
CF_Token=

# Let's Encrypt registration email for Traefik's built-in ACME resolver.
ACME_EMAIL=ofayese@olutechsys.com

# Traefik dashboard - set true ONLY for debugging, never in production.
# When true: access at http://10.0.1.15:9080/dashboard/ (trailing slash required)
# When false: host port 9080 serves only /ping - accessing / returns 404 (correct behaviour)
TRAEFIK_DASHBOARD=false
TRAEFIK_DASHBOARD_PORT=9080
TRAEFIK_LOG_LEVEL=WARN

# Host-side publish ports.
# CRITICAL: These map host ports to Traefik's INTERNAL entrypoints (:80 and :443).
# The container listens on :80 (web) and :443 (websecure) internally.
# If these point to wrong internal ports, Docker reports
# "server unexpectedly dropped the connection".
#
# Default: HAProxy owns host 443/80; Traefik uses 8880→:80 and 6443→:443.
# To run Traefik directly on 80/443 (no HAProxy):
#   TRAEFIK_HTTP_PUBLISH=80
#   TRAEFIK_HTTPS_PUBLISH=443
TRAEFIK_HTTP_PUBLISH=8880
TRAEFIK_HTTPS_PUBLISH=6443

# Timezone
TZ=America/New_York

# ── Standard repo vars ────────────────────────────────────────────
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
ACME_CERT_ROOT=/volume1/certs/acme
