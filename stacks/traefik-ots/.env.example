# ── traefik-ots ────────────────────────────────────────────────────
# Cloudflare API token — same token as acme-sh stack (Zone.DNS:Edit)
CF_Token=

# Let's Encrypt registration email for Traefik's built-in ACME resolver (Cloudflare DNS-01).
# Required for Traefik to start with certificatesResolvers.cloudflare enabled.
ACME_EMAIL=ofayese@olutechsys.com

# Traefik dashboard (set true only for debugging — never in production)
TRAEFIK_DASHBOARD=false
TRAEFIK_DASHBOARD_PORT=8080
TRAEFIK_LOG_LEVEL=WARN

# Host-side publish ports (defaults 80 / 443). Set alternates if Docker reports "listen tcp4 ...:443: address already in use".
# Example (HAProxy keeps 443; Traefik listens on high ports): TRAEFIK_HTTP_PUBLISH=9080 TRAEFIK_HTTPS_PUBLISH=9443
TRAEFIK_HTTP_PUBLISH=80
TRAEFIK_HTTPS_PUBLISH=443

# Timezone
TZ=America/New_York

# ── Standard repo vars ────────────────────────────────────────────
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
ACME_CERT_ROOT=/volume1/certs/acme
