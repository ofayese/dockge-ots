# Get a team or personal API key: Warp → Settings → Platform → API keys (prefix wk-).
# Copy this file to .env and set the value:
#   cp .env.example .env
WARP_API_KEY=

# NAS / repo default — passed to warp-agent `user:` (see HIVE_OBJECTIVE.md).
PUID=0
PGID=0

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/dockge/stacks
