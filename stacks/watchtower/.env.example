# Stack: watchtower - tunables for notifications and schedule (optional env_file).
#
# Bearer token for Watchtower HTTP API is not set here. compose.yaml mounts it via
# Docker secrets from grafana-prom (see that stack's secrets/README.md). Do not add
# bare filesystem paths as their own line; Compose .env requires KEY=value or a full-line # comment.
#
# compose.yaml uses WATCHTOWER_NOTIFICATIONS=shoutrrr and WATCHTOWER_NOTIFICATION_URL=${WATCHTOWER_NOTIFICATION_URL}.
# Shoutrrr Discord URL shape (replace placeholders on the NAS only; never commit real tokens/webhooks to git):
#   discord://<token>@<webhook_id>
# Copy the webhook token and numeric webhook id from Discord channel settings; keep this file as examples only.
# Do not commit real webhook URLs or tokens — use a gitignored stacks/watchtower/.env on the host.
#
# Non-secret placeholder for local/CI compose config checks (no outbound notify):
WATCHTOWER_NOTIFICATION_URL=logger://

TZ=America/New_York
WATCHTOWER_LABEL_ENABLE=true
WATCHTOWER_CLEANUP=true
WATCHTOWER_INCLUDE_STOPPED=false
WATCHTOWER_SCHEDULE=0 0 4 * * *
WATCHTOWER_NOTIFICATIONS=shoutrrr
WATCHTOWER_NOTIFICATION_REPORT=true

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
