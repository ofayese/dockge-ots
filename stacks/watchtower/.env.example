# Stack: watchtower
# Tunables for notifications and schedule (optional env_file).
#
# HTTP API / Prometheus metrics use a bearer token file shared with Grafana/Prometheus:
#   ../grafana-prom/secrets/watchtower_bearer_token.txt
# See ../grafana-prom/secrets/README.md — do not put that token in git.

TZ=America/New_York
WATCHTOWER_LABEL_ENABLE=true
WATCHTOWER_CLEANUP=true
WATCHTOWER_INCLUDE_STOPPED=false
WATCHTOWER_SCHEDULE=0 0 4 * * *
WATCHTOWER_NOTIFICATIONS=shoutrrr
WATCHTOWER_NOTIFICATION_URL=logger://
WATCHTOWER_NOTIFICATION_REPORT=true

# Host bind-mount root (see repo-root `.env.example`; init-nas.sh sets this on the NAS).
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
