# Copy to .env and set strong secrets. Never commit .env.
STACK_ROOT=/volume1/docker/dockge/stacks
PUID=0
PGID=0
TZ=America/New_York

POSTGRES_DB=zabbix
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=changeme

ZABBIX_WEB_PORT=8532
ZABBIX_SERVER_PUBLISH=10051

# Optional: when you enable the commented zabbix-agent2 service.
# ZBX_AGENT_HOSTNAME=zabbix-agent-docker
